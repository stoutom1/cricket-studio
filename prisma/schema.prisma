generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                           @id @default(uuid())
  email                      String                           @unique
  name                       String?
  password                   String
  ownedLeagues               League[]
  leagueMemberships          LeagueMember[]
  leagueRegistrations        LeagueRegistration[]
  activeLeagueId             Int?
  activeMatchId              Int?
  resetToken                 String?
  resetTokenExpiry           DateTime?
  createdAt                  DateTime                         @default(now())
  leagueFollowers            LeagueFollower[]
  lastLoginAt                DateTime?
  lastSeenAt                 DateTime?
  loginHistory               LoginHistory[]
  birthdaysCreated           LeagueBirthday[]                 @relation("BirthdayCreatedBy")
  birthdaysUpdated           LeagueBirthday[]                 @relation("BirthdayUpdatedBy")
  pushDevices                PushDevice[]
  birthdayPreferences        BirthdayNotificationPreference[]
  birthdayReminderRecipients BirthdayReminderLog[]            @relation("BirthdayReminderRecipient")
  birthdayRemindersShared    BirthdayReminderLog[]            @relation("BirthdayReminderSharedBy")
  webPushSubscriptions       WebPushSubscription[]
}

model Team {
  id                  Int      @id @default(autoincrement())
  name                String
  createdAt           DateTime @default(now())
  battingFirstMatches Match[]  @relation("BattingFirstTeam")
  matchesA            Match[]  @relation("TeamA")
  matchesB            Match[]  @relation("TeamB")
  players             Player[]
  leagueId            Int
  league              League   @relation(fields: [leagueId], references: [id])

  @@unique([leagueId, name])
}

model Player {
  id              Int              @id @default(autoincrement())
  name            String
  teamId          Int
  createdAt       DateTime         @default(now())
  bowlerBalls     Ball[]           @relation("Bowler")
  dismissedBalls  Ball[]           @relation("DismissedPlayer")
  newBatterBalls  Ball[]           @relation("NewBatter")
  nonStrikerBalls Ball[]           @relation("NonStriker")
  strikerBalls    Ball[]           @relation("Striker")
  team            Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leagueBirthdays LeagueBirthday[]
  whatsappNumber  String?
  whatsappOptIn   Boolean          @default(false)

  @@unique([teamId, name])
  @@index([teamId])
}

model Match {
  id                    Int                  @id @default(autoincrement())
  shareCode             String?              @unique
  teamAId               Int
  teamBId               Int
  battingFirstTeamId    Int?
  oversPerInnings       Int
  powerplayOversInnings Int                  @default(0)
  status                String               @default("in_progress")
  createdAt             DateTime             @default(now())
  scheduledAt           DateTime?
  statusText            String?              @default("LIVE")
  maxOversPerBowler     Int?
  maxWicketsPerInnings  Int?
  balls                 Ball[]
  battingFirstTeam      Team?                @relation("BattingFirstTeam", fields: [battingFirstTeamId], references: [id])
  teamA                 Team                 @relation("TeamA", fields: [teamAId], references: [id])
  teamB                 Team                 @relation("TeamB", fields: [teamBId], references: [id])
  state                 MatchState?
  leagueId              Int?
  league                League?              @relation(fields: [leagueId], references: [id])
  events                MatchEvent[]
  aiAnalysis            String?
  aiAnalysisAt          DateTime?
  seriesId              Int?
  series                Series?              @relation(fields: [seriesId], references: [id])
  innings1EndedManually Boolean              @default(false)
  teamACaptainId        Int?
  teamBCaptainId        Int?
  teamAWicketKeeperId   Int?
  teamBWicketKeeperId   Int?
  wicketKeeperChanges   WicketKeeperChange[]
  startedAt             DateTime?
  endedAt               DateTime?
  lockedAt              DateTime?
}

model Ball {
  id                 Int      @id @default(autoincrement())
  matchId            Int
  inningsNo          Int
  sequence           Int
  overNo             Int
  ballInOver         Int
  legalDelivery      Boolean
  strikerId          Int?
  nonStrikerId       Int?
  bowlerId           Int?
  dismissedPlayerId  Int?
  newBatterId        Int?
  runsOffBat         Int      @default(0)
  extras             Int      @default(0)
  extraType          String   @default("NONE")
  totalRuns          Int      @default(0)
  isWicket           Int      @default(0)
  wicketType         String   @default("NONE")
  isPowerPlay        Boolean  @default(false)
  note               String?
  createdAt          DateTime @default(now())
  bowler             Player?  @relation("Bowler", fields: [bowlerId], references: [id])
  dismissedPlayer    Player?  @relation("DismissedPlayer", fields: [dismissedPlayerId], references: [id])
  match              Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  newBatter          Player?  @relation("NewBatter", fields: [newBatterId], references: [id])
  nonStriker         Player?  @relation("NonStriker", fields: [nonStrikerId], references: [id])
  striker            Player?  @relation("Striker", fields: [strikerId], references: [id])
  fielderId          Int?
  assistantFielderId Int?
  wicketNote         String?

  @@unique([matchId, inningsNo, sequence])
  @@index([matchId, inningsNo, sequence])
}

model MatchState {
  matchId      Int   @id
  inningsNo    Int
  strikerId    Int?
  nonStrikerId Int?
  bowlerId     Int?
  match        Match @relation(fields: [matchId], references: [id])
}

model League {
  id                   Int                              @id @default(autoincrement())
  name                 String                           @unique
  createdAt            DateTime                         @default(now())
  ownerId              String?
  owner                User?                            @relation(fields: [ownerId], references: [id])
  teams                Team[]
  registrations        LeagueRegistration[]
  members              LeagueMember[]
  invites              LeagueInvite[]
  matches              Match[]
  visibility           String                           @default("PRIVATE")
  slug                 String?                          @unique
  series               Series[]
  leagueFollowers      LeagueFollower[]
  birthdays            LeagueBirthday[]
  birthdayPreferences  BirthdayNotificationPreference[]
  birthdayReminderLogs BirthdayReminderLog[]
}

model LeagueRegistration {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  leagueId  Int
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@unique([leagueId, userId])
}

model LeagueMember {
  id Int @id @default(autoincrement())

  userId   String
  leagueId Int

  joinedAt DateTime @default(now())

  role String @default("VIEWER")

  // Navigation
  canViewDashboard  Boolean @default(true)
  canViewManagement Boolean @default(false)
  canViewMatches    Boolean @default(true)
  canViewScoring    Boolean @default(false)
  canViewStats      Boolean @default(true)

  // League
  canCreateLeague      Boolean @default(false)
  canEditLeague        Boolean @default(false)
  canDeleteLeague      Boolean @default(false)
  canManageMembers     Boolean @default(false)
  canManagePermissions Boolean @default(false)

  // Teams
  canCreateTeam Boolean @default(false)
  canEditTeam   Boolean @default(false)
  canDeleteTeam Boolean @default(false)

  // Players
  canCreatePlayer Boolean @default(false)
  canEditPlayer   Boolean @default(false)
  canDeletePlayer Boolean @default(false)

  // Matches
  canCreateMatch  Boolean @default(false)
  canEditMatch    Boolean @default(false)
  canDeleteMatch  Boolean @default(false)
  canEndMatch     Boolean @default(false)
  canAbandonMatch Boolean @default(false)
  canLockMatch    Boolean @default(false)

  // Scoring
  canScoreMatch   Boolean @default(false)
  canEditScore    Boolean @default(false)
  canUndoBall     Boolean @default(false)
  canSwapStrike   Boolean @default(false)
  canRetirePlayer Boolean @default(false)

  // Statistics
  canExportStats Boolean @default(false)

  // Admin
  canViewAuditLogs Boolean @default(false)

  // Polling and Team Splits
  canUseTeamBuilder         Boolean @default(false)
  canCreateAvailabilityPoll Boolean @default(false)

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, leagueId])
}

model LeagueInvite {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  leagueId  Int
  league    League   @relation(fields: [leagueId], references: [id])
  createdAt DateTime @default(now())
}

model MatchEvent {
  id Int @id @default(autoincrement())

  matchId   Int
  inningsNo Int

  eventType String

  playerId      Int?
  replacementId Int?

  strikerId    Int?
  nonStrikerId Int?

  note String?

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, inningsNo])
}

model Series {
  id          Int      @id @default(autoincrement())
  leagueId    Int
  name        String
  year        Int
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  league  League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  matches Match[]
}

model CorrectionLog {
  id               Int       @id @default(autoincrement())
  matchId          Int
  type             String
  correctionBallId Int?
  payload          Json?
  beforeBalls      Json?
  createdAt        DateTime  @default(now())
  revertedAt       DateTime?

  correctionType  String? @default("RETIRED_HURT")
  correctionLabel String?
  reason          String?

  beforeJson Json?
  afterJson  Json?

  correctedById    Int?
  correctedByName  String?
  correctedByEmail String?
}

model WicketKeeperChange {
  id            Int      @id @default(autoincrement())
  matchId       Int
  inningsNo     Int
  afterSequence Int      @default(0)
  teamId        Int
  oldKeeperId   Int?
  newKeeperId   Int
  note          String?
  createdAt     DateTime @default(now())
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model LeagueFollower {
  id        Int      @id @default(autoincrement())
  userId    String
  leagueId  Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

model AuditLog {
  id Int @id @default(autoincrement())

  action     String
  entityType String
  entityId   Int?

  leagueId Int?
  matchId  Int?
  teamId   Int?
  playerId Int?

  actorUserId Int?
  actorName   String?
  actorEmail  String?

  description String?
  beforeData  Json?
  afterData   Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([leagueId])
  @@index([matchId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model LoginHistory {
  id Int @id @default(autoincrement())

  userId String
  email  String
  name   String?

  loginAt DateTime @default(now())

  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([loginAt])
  @@index([userId])
  @@index([email])
}

model TeamBalanceVote {
  id        Int      @id @default(autoincrement())
  matchId   Int
  voterName String?
  vote      String // FAIR, UNFAIR
  comment   String?
  createdAt DateTime @default(now())
}

model TeamBalanceSuggestion {
  id                Int      @id @default(autoincrement())
  matchId           Int
  fromTeamAPlayerId Int
  fromTeamBPlayerId Int
  reason            String?
  createdAt         DateTime @default(now())
}

model TeamAvailabilityPoll {
  id            Int                        @id @default(autoincrement())
  token         String                     @unique
  leagueId      Int?
  title         String
  matchText     String?
  startTime     DateTime?
  status        String                     @default("OPEN") // OPEN, CLOSED
  createdAt     DateTime                   @default(now())
  options       TeamAvailabilityOption[]
  responses     TeamAvailabilityResponse[]
  sourceTeamIds String?
}

model TeamAvailabilityOption {
  id        Int       @id @default(autoincrement())
  pollId    Int
  label     String // Friday, Saturday, Sunday
  startTime DateTime?
  sortOrder Int       @default(0)

  poll      TeamAvailabilityPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  responses TeamAvailabilityResponse[]
}

model TeamAvailabilityResponse {
  id          Int      @id @default(autoincrement())
  pollId      Int
  optionId    Int
  playerKey   String
  playerName  String
  response    String // YES, MAYBE, NO
  displayName String?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  poll   TeamAvailabilityPoll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option TeamAvailabilityOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, optionId, playerKey])
}

model MatchCorrection {
  id Int @id @default(autoincrement())

  matchId  Int
  leagueId Int?

  correctionType  String
  correctionLabel String?

  beforeJson Json
  afterJson  Json

  reason String?

  correctedById    Int?
  correctedByName  String?
  correctedByEmail String?

  rolledBackAt   DateTime?
  rolledBackById Int?

  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([leagueId])
  @@index([correctionType])
  @@index([createdAt])
}

enum BirthdayReminderType {
  DAY_BEFORE
  BIRTHDAY_TODAY
}

enum BirthdayReminderStatus {
  PENDING
  SENT
  FAILED
  SHARED
}

model LeagueBirthday {
  id         Int     @id @default(autoincrement())
  leagueId   Int
  playerId   Int
  name       String
  birthMonth Int
  birthDay   Int
  notes      String?
  isActive   Boolean @default(true)

  createdById String
  updatedById String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  whatsappNumber String?
  whatsappOptIn  Boolean  @default(false)

  league    League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  createdBy User   @relation("BirthdayCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?  @relation("BirthdayUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  reminders BirthdayReminderLog[]
  player    Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
  @@index([leagueId])
  @@index([leagueId, birthMonth, birthDay])
  @@index([leagueId, isActive])
  @@index([playerId])
}

model BirthdayNotificationPreference {
  id       Int    @id @default(autoincrement())
  userId   String
  leagueId Int

  enabled          Boolean @default(true)
  notifyDayBefore  Boolean @default(true)
  notifyOnBirthday Boolean @default(true)
  reminderHour     Int     @default(8)
  timeZone         String  @default("America/Los_Angeles")

  emailFallbackEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId, enabled])
}

model PushDevice {
  id         Int      @id @default(autoincrement())
  userId     String
  token      String   @unique
  platform   String
  deviceName String?
  enabled    Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
}

model BirthdayReminderLog {
  id              Int                    @id @default(autoincrement())
  birthdayId      Int
  leagueId        Int
  recipientUserId String
  birthdayYear    Int
  reminderType    BirthdayReminderType
  status          BirthdayReminderStatus @default(PENDING)

  notificationTitle String?
  notificationBody  String?
  errorMessage      String?

  sentAt     DateTime?
  sharedAt   DateTime?
  sharedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  birthday  LeagueBirthday @relation(fields: [birthdayId], references: [id], onDelete: Cascade)
  league    League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  recipient User           @relation("BirthdayReminderRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  sharedBy  User?          @relation("BirthdayReminderSharedBy", fields: [sharedById], references: [id], onDelete: SetNull)

  @@unique([birthdayId, recipientUserId, birthdayYear, reminderType])
  @@index([leagueId, birthdayYear])
  @@index([recipientUserId, status])
}

model WebPushSubscription {
  id Int @id @default(autoincrement())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  expirationTime BigInt?

  userAgent  String?
  deviceName String?

  isActive Boolean @default(true)

  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([userId, isActive])
}
